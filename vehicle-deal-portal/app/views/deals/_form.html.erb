<%= form_with(model: deal) do |form| %>
  <% if deal.errors.any? %>
    <div style="color: red">
      <h2><%= pluralize(deal.errors.count, "error") %> prohibited this deal from being saved:</h2>

      <ul>
        <% deal.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= form.label :deal_date, style: "display: block" %>
    <%= form.date_field :deal_date %>
  </div>

  <div>
    <%= form.label :deal_number, style: "display: block" %>
    <%= form.text_field :deal_number %>
  </div>

  <div>
    <%= form.label :stock_number, style: "display: block" %>
    <%= form.text_field :stock_number %>
  </div>

  <div>
    <%= form.label :salesperson, style: "display: block" %>
    <%= form.text_field :salesperson %>
  </div>

  <div>
    <%= form.label :vehicle_type, style: "display: block" %>
    <%= form.text_field :vehicle_type %>
  </div>

  <div>
    <%= form.label :customer_name, style: "display: block" %>
    <%= form.text_field :customer_name %>
  </div>

  <div>
    <%= form.label :vehicle_purchased, style: "display: block" %>
    <%= form.text_field :vehicle_purchased %>
  </div>

  <div>
    <%= form.label :has_trade, style: "display: block" %>
    <%= form.check_box :has_trade %>
  </div>

  <div>
    <%= form.label :contact_number, style: "display: block" %>
    <%= form.text_field :contact_number %>
  </div>

  <div>
    <%= form.label :status, style: "display: block" %>
    <%= form.select :status, Deal::STATUSES %>
  </div>

  <div>
    <%= form.label :estimated_delivery_date, style: "display: block" %>
    <%= form.date_field :estimated_delivery_date %>
  </div>

  <div>
    <%= form.label :notes, style: "display: block" %>
    <%= form.text_area :notes %>
  </div>

  <div>
    <%= form.label :documents, "Upload documents", style: "display: block" %>
    <%= form.file_field :documents, multiple: true %>
  </div>

  <div>
    <%= form.submit %>
  </div>
<% end %>
