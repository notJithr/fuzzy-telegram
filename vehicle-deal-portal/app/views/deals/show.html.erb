<p style="color: green"><%= notice %></p>

<%= render @deal %>

<div>
  <%= link_to "Edit this deal", edit_deal_path(@deal) %> |
  <%= link_to "Back to deals", deals_path %>

  <%= button_to "Destroy this deal", @deal, method: :delete %>
</div>

<h2>Documents</h2>

<% if @deal.documents.attached? %>
  <ul>
    <% @deal.documents.each do |document| %>
      <li>
        <%= link_to document.filename, document, target: "_blank" %>
      </li>
    <% end %>
  </ul>
<% else %>
  <p>No documents uploaded.</p>
<% end %>
